  "keyFeatures": [
    "Property listing and search with advanced filters",
    "Multi-field intelligent search with synonyms and autocomplete",
    "User authentication with Better Auth (email/password and Google OAuth)",
    "Interactive property maps with Google Maps and Leaflet",
    "Admin panel for property and user management",
    "Favorites system for authenticated users",
    "Drag-and-drop image management for property listings",
    "Address autocomplete with geolocation",
    "Responsive design with Tailwind CSS",
    "Full-text search with PostgreSQL"
  ],
  "publicApiSurface": [
    "GET /api/properties - List properties with filters",
    "GET /api/properties/:id - Get property by ID",
    "GET /api/properties/slug/:slug - Get property by URL slug",
    "POST /api/properties - Create new property",
    "PUT /api/properties/:id - Update property",
    "DELETE /api/properties/:id - Delete property",
    "POST /api/properties/:id/favorite - Add property to favorites",
    "DELETE /api/properties/:id/favorite - Remove property from favorites",
    "GET /api/users/profile - Get user profile",
    "PUT /api/users/profile - Update user profile",
    "GET /api/users/favorites - Get user's favorite properties",
    "GET /api/metadata/all - Get all metadata (types, subtypes, features, etc.)",
    "GET /api/metadata/property-types - Get property types",
    "GET /api/metadata/property-subtypes - Get property subtypes",
    "GET /api/metadata/operation-types - Get operation types (sale, rent, etc.)",
    "GET /api/metadata/features - Get available property features",
    "GET /api/metadata/tags - Get available property tags",
    "GET /api/admin/stats - Get admin statistics",
    "GET /api/admin/properties - Get all properties (admin)",
    "GET /api/admin/users - Get all users (admin)",
    "PUT /api/admin/users/:id/role - Update user role",
    "PUT /api/admin/properties/:id/status - Update property status",
    "POST /api/admin/create-admin - Create admin user",
    "POST /api/contact/appraisal - Submit property appraisal request"
  ]
}
